# Server
PORT=3000
SESSION_SECRET=dev-only-change-me
APP_BASE_URL=http://localhost:3000
DRY_RUN=false

# MongoDB local development storage
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_DB=docs_ai_assistant
# Optional override if you prefer a full connection string.
# MONGODB_URI=mongodb://127.0.0.1:27017

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Scope mode:
# docs_only requests the minimum Docs read/write scope.
# with_drive also requests Drive metadata scope so the app can list recent Docs.
GOOGLE_SCOPE_MODE=docs_only

# AI provider: openai-compatible | anthropic | local | github-copilot
AI_PROVIDER=openai-compatible
AI_API_KEY=your-api-key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini
AI_MAX_TOKENS=8192

# Anthropic example
# AI_PROVIDER=anthropic
# AI_API_KEY=your-anthropic-api-key
# AI_MODEL=claude-3-5-sonnet-latest

# Local/private OpenAI-compatible example
# AI_PROVIDER=local
# AI_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=not-needed
# AI_MODEL=local-model-name

# Experimental GitHub Copilot provider.
# Recommended path: use the in-app "Connect Copilot" device-login flow.
# AI_PROVIDER=github-copilot
# AI_MODEL=claude-sonnet-4
#
# Optional override. By default, the app uses the public VS Code Copilot OAuth
# client ID used by Copilot-compatible local tools.
# GITHUB_COPILOT_CLIENT_ID=Iv1.b507a08c87ecfe98
# GITHUB_COPILOT_HOST=github.com
# GITHUB_COPILOT_API_BASE_URL=https://api.githubcopilot.com
# Optional token import. OAuth/device tokens work; PATs usually cannot produce
# Copilot chat tokens.
# COPILOT_GITHUB_TOKEN=gho_or_ghu_oauth_token
# GH_TOKEN=gho_or_ghu_oauth_token
# GITHUB_TOKEN=gho_or_ghu_oauth_token
# Leave false unless you specifically need the older internal token exchange path.
# GITHUB_COPILOT_USE_TOKEN_EXCHANGE=false
